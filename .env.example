# Anthropic API key — required to run the agent
ANTHROPIC_API_KEY=sk-ant-...

# Model id (optional, defaults to claude-sonnet-4-6)
THREAT_INTEL_MODEL=claude-sonnet-4-6

# --- Live data sources (all free; only needed for --backend live / feed) ----
# VirusTotal free API key: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
# AbuseIPDB free API key: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=
# abuse.ch ThreatFox Auth-Key (free): https://auth.abuse.ch/
THREATFOX_AUTH_KEY=

# --- Auth (set in production to require login) -------------------------------
# Shared login password. If empty, the API is OPEN (no login) — fine locally.
APP_PASSWORD=
# Secret used to sign session cookies. Use a long random string in production.
SESSION_SECRET=
